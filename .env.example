HEDERA_ACCOUNT_ID=
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=testnet
HEDERA_HCS_TOPIC_ID=
HEDERA_RPC_URL=https://testnet.hashio.io/api
ERC8004_CHAIN_ID=

OPENAI_API_KEY=
IDENTITY_CONTRACT_ADDRESS=
REPUTATION_CONTRACT_ADDRESS=
VALIDATION_CONTRACT_ADDRESS=

RESEARCH_API_URL=https://localhost:5001
NEXT_PUBLIC_BACKEND_URL=https://localhost:8000

#for dev
# RESEARCH_API_URL=http://localhost:5001
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Hashgraph Online Registry Broker (HOL)
REGISTRY_BROKER_API_URL=https://hol.org/registry/api/v1
REGISTRY_BROKER_API_KEY=
# Optional Python API -> HOL sidecar request timeout (seconds).
# Increase if HOL registration frequently times out under load/cold starts.
# HOL_SDK_SIDECAR_TIMEOUT_SECONDS=60
# Optional connect timeout (seconds) for sidecar requests.
# HOL_SDK_SIDECAR_CONNECT_TIMEOUT_SECONDS=5
# Optional registration timeout (seconds, default 180).
# Increase if HOL registration frequently times out after Pinata succeeds.
# HOL_SDK_SIDECAR_REGISTER_TIMEOUT_SECONDS=180
# Optional create-session timeout (seconds, default 120).
# HOL_SDK_SIDECAR_CREATE_SESSION_TIMEOUT_SECONDS=120
# Optional retry count for create-session timeouts and transient 5xx (default 2).
# HOL_SDK_SIDECAR_CREATE_SESSION_RETRIES=2
# Optional base backoff between retries in seconds (default 2.0).
# HOL_SDK_SIDECAR_CREATE_SESSION_RETRY_BACKOFF_SECONDS=2.0
# Optional: override registration endpoint if broker path differs by environment.
# REGISTRY_BROKER_REGISTER_PATH=/register
# Optional: comma-separated fallback list (takes precedence over single path).
# REGISTRY_BROKER_REGISTER_PATHS=/register,/agents/register
# Optional paid fan-out registries for marketplace "Register on HOL".
# Leave unset/empty for free-tier registration behavior.
# HOL_REGISTER_ADDITIONAL_REGISTRIES=erc-8004:skale-base

# Database
DATABASE_URL=
# For SQLite (local development only):
# DATABASE_URL=sqlite:///./hedera_marketplace.db
# Or leave unset to use default SQLite

PINATA_API_KEY=
PINATA_SECRET_KEY=
# Optional alternative to API key/secret:
# PINATA_JWT=
DATA_AGENT_AUTO_ANCHOR=0
SERPER_API_KEY=
TAVILY_API_KEY=
# Optional: higher rate limits for academic search APIs
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=

#If you actually want managed/dev_env
# TASK_ESCROW_ADDRESS=
# TASK_ESCROW_MARKETPLACE_TREASURY=
# TASK_ESCROW_OPERATOR_PRIVATE_KEY=
